{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "BIN=\"$CLAUDE_PROJECT_DIR/tools/silo-kb/silo-kb\"; [ -x \"$BIN\" ] || exit 0; exec \"$BIN\" validate --hook-stdin"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "BIN=\"$CLAUDE_PROJECT_DIR/tools/silo-kb/silo-kb\"; [ -x \"$BIN\" ] || exit 0; cd \"$CLAUDE_PROJECT_DIR\" && \"$BIN\" inject-index --budget 4000 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-end-extract.sh\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
